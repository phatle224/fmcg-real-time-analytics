{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "4.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Vinamilk FMCG Real-Time POS Analytics — Hot Path Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Real-Time Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "currencyVND"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Revenue Today",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
          "rawSql": "SELECT toStartOfMinute(now()) AS time, sumMerge(revenue) AS value FROM pos_hourly_agg WHERE hour >= toStartOfDay(now()) FORMAT JSONEachRow",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Transactions Today",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
          "rawSql": "SELECT count() AS value FROM pos_transactions WHERE toDate(timestamp) = today() FORMAT JSONEachRow",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 900 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg Basket Size (VND)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
          "rawSql": "SELECT round(avg(total_amount)) AS value FROM pos_transactions WHERE toDate(timestamp) = today() FORMAT JSONEachRow",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Units Sold Today",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
          "rawSql": "SELECT sum(quantity) AS value FROM pos_transactions WHERE toDate(timestamp) = today() FORMAT JSONEachRow",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "unit": "currencyVND"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 5 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Revenue Per Minute by Region",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
          "rawSql": "SELECT toStartOfMinute(timestamp) AS time, region, sum(total_amount) AS value FROM pos_transactions WHERE $__timeFilter(timestamp) GROUP BY time, region ORDER BY time ASC FORMAT JSONEachRow",
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyVND"
        }
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 5 },
      "id": 6,
      "options": { "displayLabels": ["percent"], "legend": { "displayMode": "list", "placement": "bottom" }, "pieType": "donut" },
      "title": "Revenue by Category",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
          "rawSql": "SELECT category, sum(total_amount) AS value FROM pos_transactions WHERE toDate(timestamp) = today() GROUP BY category ORDER BY value DESC FORMAT JSONEachRow",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "barAlignment": 0, "drawStyle": "bars" },
          "unit": "currencyVND"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" }, "orientation": "horizontal" },
      "title": "Top 10 Products by Revenue (Today)",
      "type": "barchart",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
          "rawSql": "SELECT product_name, sum(total_amount) AS revenue FROM pos_transactions WHERE toDate(timestamp) = today() GROUP BY product_name ORDER BY revenue DESC LIMIT 10 FORMAT JSONEachRow",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Transaction Rate per Minute (tx/min)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse-fmcg" },
          "rawSql": "SELECT toStartOfMinute(timestamp) AS time, count() AS value FROM pos_transactions WHERE $__timeFilter(timestamp) GROUP BY time ORDER BY time ASC FORMAT JSONEachRow",
          "refId": "A",
          "format": "time_series"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["fmcg", "vinamilk", "realtime", "clickhouse"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "FMCG Real-Time POS Analytics",
  "uid": "fmcg-realtime-pos",
  "version": 1
}
